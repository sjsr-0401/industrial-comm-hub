<Window x:Class="IndustrialCommHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IndustrialCommHub.Views"
        xmlns:vm="clr-namespace:IndustrialCommHub.ViewModels"
        Title="Industrial Communication Hub  —  Protocol Reference &amp; Simulator"
        Height="820" Width="1300"
        MinHeight="600" MinWidth="900"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#FF252525" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="22" Foreground="#FF0078D7" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Industrial Communication Hub" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Protocol Reference &amp; Simulator  ·  Portfolio Edition" FontSize="11" Foreground="#FF9E9E9E"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FF0078D730" CornerRadius="12" Padding="10,4" Margin="4,0">
                        <TextBlock Text=".NET 8 / WPF" FontSize="11" Foreground="#FF0078D7"/>
                    </Border>
                    <Border Background="#FF4CAF5030" CornerRadius="12" Padding="10,4" Margin="4,0">
                        <TextBlock Text="MVVM" FontSize="11" Foreground="#FF81C784"/>
                    </Border>
                    <Border Background="#FFFFC10730" CornerRadius="12" Padding="10,4" Margin="4,0">
                        <TextBlock Text="ScottPlot 5" FontSize="11" Foreground="#FFFFC107"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Tab Control -->
        <TabControl Grid.Row="1" Margin="0">
            <!-- Tab 1: Modbus -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📡 " FontSize="13"/>
                        <TextBlock Text="Modbus TCP/RTU"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ModbusView DataContext="{Binding Modbus}"/>
            </TabItem>

            <!-- Tab 2: Serial -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔌 " FontSize="13"/>
                        <TextBlock Text="Serial RS-232/485"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SerialView DataContext="{Binding Serial}"/>
            </TabItem>

            <!-- Tab 3: Motion -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡ " FontSize="13"/>
                        <TextBlock Text="Motion Control"/>
                    </StackPanel>
                </TabItem.Header>
                <views:MotionView DataContext="{Binding Motion}"/>
            </TabItem>

            <!-- Tab 4: PLC -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏭 " FontSize="13"/>
                        <TextBlock Text="PLC Communication"/>
                    </StackPanel>
                </TabItem.Header>
                <views:PlcView DataContext="{Binding Plc}"/>
            </TabItem>

            <!-- Tab 5: SECS/GEM -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💎 " FontSize="13"/>
                        <TextBlock Text="SECS/GEM"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SecsGemView DataContext="{Binding SecsGem}"/>
            </TabItem>

            <!-- Tab 6: Protocol Compare -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " FontSize="13"/>
                        <TextBlock Text="Protocol Comparison"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ProtocolCompareView DataContext="{Binding ProtocolCompare}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FF252525" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Industrial Communication Hub  —  Portfolio Reference Application"
                           Foreground="#FF555555" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Modbus · EtherCAT · SSCNET · PMAC · CC-Link · PROFINET · SECS/GEM"
                           Foreground="#FF444444" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
