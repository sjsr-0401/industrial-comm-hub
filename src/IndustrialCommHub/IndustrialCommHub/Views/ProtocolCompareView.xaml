<UserControl x:Class="IndustrialCommHub.Views.ProtocolCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Industrial Protocol Comparison" Style="{StaticResource HeaderText}"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,0"
                           Text="주요 산업용 통신 프로토콜의 성능, 토폴로지, 적용 범위를 한눈에 비교합니다."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Protocols}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="프로토콜" Binding="{Binding Protocol}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF0078D7"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="4,6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="통신 속도" Binding="{Binding Speed}" Width="180"/>
                    <DataGridTextColumn Header="토폴로지" Binding="{Binding Topology}" Width="140"/>
                    <DataGridTextColumn Header="최대 노드" Binding="{Binding MaxNodes}" Width="110"/>
                    <DataGridTextColumn Header="실시간성" Binding="{Binding RealTime}" Width="160"/>
                    <DataGridTextColumn Header="주요 용도" Binding="{Binding MainUse}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
