<UserControl x:Class="IndustrialCommHub.Views.SecsGemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- SEMI Standards -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="SEMI Standards Overview" Style="{StaticResource HeaderText}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FF252525" CornerRadius="5" Padding="12" Margin="0,0,8,0" BorderBrush="#FF0078D7" BorderThickness="0,0,0,3">
                            <StackPanel>
                                <TextBlock Text="SEMI E5" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="SECS-II" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,8"/>
                                <TextBlock Style="{StaticResource BodyText}"
                                           Text="SECS Message Services. 반도체 장비와 호스트 간의 메시지 형식과 의미(Semantics)를 정의. Stream(S)과 Function(F)으로 구성된 이진 메시지 포맷. S1F1~S21Fx 지원."/>
                                <Border Background="#FF1A1A2E" CornerRadius="3" Padding="8,6" Margin="0,8,0,0">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#FF9CDCFE"
                                               Text="S1F1 : Are You There (H→E)&#x0a;S1F2 : On Line Data (E→H)&#x0a;S6F11: Event Report Send&#x0a;S7F1 : Process Program Load"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FF252525" CornerRadius="5" Padding="12" Margin="4,0" BorderBrush="#FF4CAF50" BorderThickness="0,0,0,3">
                            <StackPanel>
                                <TextBlock Text="SEMI E30" Foreground="#FF81C784" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="GEM" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,8"/>
                                <TextBlock Style="{StaticResource BodyText}"
                                           Text="Generic Equipment Model. 반도체 장비가 갖춰야 할 기본 동작과 인터페이스를 표준화. 장비 상태 관리, 알람, 이벤트 리포트, 레시피 관리, 원격 제어, 시간 동기화, 스풀링 등 13가지 GEM capability 정의."/>
                                <Border Background="#FF1A1A2E" CornerRadius="3" Padding="8,6" Margin="0,8,0,0">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#FF9CDCFE"
                                               Text="GEM Capabilities:&#x0a;- Equipment Processing States&#x0a;- Alarm Management&#x0a;- Remote Control&#x0a;- Collection Events"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FF252525" CornerRadius="5" Padding="12" Margin="8,0,0,0" BorderBrush="#FFFFC107" BorderThickness="0,0,0,3">
                            <StackPanel>
                                <TextBlock Text="SEMI E37" Foreground="#FFFFC107" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="HSMS" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,8"/>
                                <TextBlock Style="{StaticResource BodyText}"
                                           Text="High-Speed Message Services. TCP/IP 위에서 SECS-II 메시지를 전송하는 전송 계층 프로토콜. 포트 5000 기본. HSMS-SS(Single Session)와 HSMS-GS(General Session) 두 가지 변형. GbE 환경에서 고속 데이터 전송."/>
                                <Border Background="#FF1A1A2E" CornerRadius="3" Padding="8,6" Margin="0,8,0,0">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#FF9CDCFE"
                                               Text="Message Header: 10 bytes&#x0a;- Length: 4B&#x0a;- SessionID: 2B&#x0a;- Header: 4B (SType, PType)&#x0a;- System Bytes: 4B"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Equipment State Model -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="GEM Equipment State Model" Style="{StaticResource HeaderText}"/>
                    <TextBlock x:Name="StateModelText"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#FFE0E0E0"
                               Background="#FF0D1117"
                               Padding="16"
                               TextWrapping="NoWrap"/>
                </StackPanel>
            </Border>

            <!-- PMC-CTC-Host -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="PMC ↔ CTC ↔ Host Architecture" Style="{StaticResource HeaderText}"/>
                    <TextBlock x:Name="PmcCtcText"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#FFE0E0E0"
                               Background="#FF0D1117"
                               Padding="16"
                               TextWrapping="NoWrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
