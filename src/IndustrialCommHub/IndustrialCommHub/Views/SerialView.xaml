<UserControl x:Class="IndustrialCommHub.Views.SerialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Port Settings -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="COM Port Configuration" Style="{StaticResource HeaderText}"/>
                <WrapPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Baud Rate" Style="{StaticResource SubHeaderText}"/>
                        <ComboBox ItemsSource="{Binding BaudRates}"
                                  SelectedItem="{Binding SelectedBaud}"
                                  Width="120"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Parity" Style="{StaticResource SubHeaderText}"/>
                        <ComboBox ItemsSource="{Binding Parities}"
                                  SelectedItem="{Binding SelectedParity}"
                                  Width="100"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Data Bits" Style="{StaticResource SubHeaderText}"/>
                        <ComboBox ItemsSource="{Binding DataBitsList}"
                                  SelectedItem="{Binding SelectedDataBits}"
                                  Width="80"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Stop Bits" Style="{StaticResource SubHeaderText}"/>
                        <ComboBox ItemsSource="{Binding StopBitsList}"
                                  SelectedItem="{Binding SelectedStopBits}"
                                  Width="80"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text=" " Style="{StaticResource SubHeaderText}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>

                <!-- STX/ETX Framing Info -->
                <Border Background="#FF1A1A2E" CornerRadius="4" Padding="12,8" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="STX / ETX Framing" Style="{StaticResource SubHeaderText}"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                            <Run Text="STX (0x02)"/>
                            <Run Text=" ─── " Foreground="#FF555555"/>
                            <Run Text="Start of Text. 메시지 시작을 나타내는 제어 문자."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}">
                            <Run Text="ETX (0x03)"/>
                            <Run Text=" ─── " Foreground="#FF555555"/>
                            <Run Text="End of Text. 메시지 종료를 나타내는 제어 문자."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="프레임 구조: [STX] [Data Bytes] [ETX] [BCC/CRC (optional)]"/>
                        <TextBlock Style="{StaticResource BodyText}"
                                   Text="RS-485는 반이중(Half-Duplex) 방식으로 DE/RE 핀으로 송수신 방향을 전환합니다. Termination Resistor(120Ω)가 필요합니다."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Send -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Terminal" Style="{StaticResource HeaderText}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SendText}" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Send (Loopback)" Command="{Binding SendLoopbackCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="2"
                            Command="{Binding ToggleHexCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Width="90">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="ASCII Mode"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHexMode}" Value="True">
                                            <Setter Property="Text" Value="HEX Mode ✓"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="3" Content="Clear" Command="{Binding ClearTerminalCommand}" Style="{StaticResource SecondaryButton}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Mode: " Style="{StaticResource BodyText}"/>
                    <TextBlock Text="{Binding IsHexMode, StringFormat={}HEX Mode: {0}}"
                               Foreground="{StaticResource WarningBrush}" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Terminal Output -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <TextBox Text="{Binding Terminal, Mode=OneWay}"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#FF0D1117"
                     Foreground="#FF00FF88"
                     BorderThickness="0"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"/>
        </Border>
    </Grid>
</UserControl>
